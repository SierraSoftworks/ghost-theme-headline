{{#is "post"}}
    <aside class="gh-article-sidebar gh-project-sidebar">

        <nav class="gh-project-links" data-project-links aria-label="{{t "Project links"}}">
            <a class="gh-button-share gh-button-download" data-project-link="download" hidden>{{> "icons/download"}}<span>{{t "Download"}}</span></a>
            <a class="gh-project-link" data-project-link="documentation" hidden>{{> "icons/docs"}}<span>{{t "Documentation"}}</span></a>
            <a class="gh-project-link" data-project-link="repository" hidden>{{> "icons/github"}}<span>{{t "Source code"}}</span></a>
            <a class="gh-project-link" data-project-link="issues" hidden>{{> "icons/issues"}}<span>{{t "Issue tracker"}}</span></a>
        </nav>

        <div class="gh-article-meta">
            <div class="gh-article-meta-inner">
                <time class="gh-article-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                {{#if reading_time}}
                    <span class="gh-article-meta-sep"></span>
                    <span class="gh-article-length">{{reading_time minute=(t "1 min") minutes=(t "% min")}}</span>
                {{/if}}
            </div>
        </div>

        <a href="#/share" class="gh-button-share">{{t "Share"}}</a>

    </aside>
{{/is}}
